# ─── Supabase ────────────────────────────────────────────────────────────────

# Your Supabase project URL (found in Project Settings → API)
VITE_SUPABASE_URL=

# Supabase anon/public key — safe to expose client-side
VITE_SUPABASE_PUBLISHABLE_KEY=

# Supabase project reference ID
VITE_SUPABASE_PROJECT_ID=

# ─── AI / Edge Function Secrets ──────────────────────────────────────────────
# Set these in Supabase Dashboard → Edge Functions → Secrets
# DO NOT put these in .env.local — they are server-side only

# Groq API key — used by generate-content edge function (get from console.groq.com)
# AI_API_KEY=

# Supabase service role key — server-side only, never expose to the client
# SUPABASE_SERVICE_ROLE_KEY=
